#!/bin/sh
# Pre-commit hook — runs Go linter (includes goimports formatting check).
# Install once with: make install-hooks
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- Go (golangci-lint) ---
if git diff --cached --name-only | grep -q '\.go$'; then
  echo "golangci-lint..."
  cd "$REPO_ROOT/backend"
  # Probe whether the local Go toolchain can load the module. If go.mod
  # requires a newer toolchain than what is installed, skip with a warning
  # rather than blocking the commit — CI will enforce the full check.
  if ! go list ./... > /dev/null 2>&1; then
    echo "Warning: Go toolchain incompatible with go.mod (requires $(grep '^go ' go.mod | awk '{print "go " $2}')). Skipping local Go lint — CI will catch issues."
  else
    golangci-lint run ./...
  fi
  cd "$REPO_ROOT"
fi

# --- Frontend (ESLint) ---
if git diff --cached --name-only | grep -qE '\.(ts|tsx)$'; then
  echo "eslint..."
  cd "$REPO_ROOT/frontend"
  npm run lint
  cd "$REPO_ROOT"
fi
